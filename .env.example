# PostgreSQL
DATABASE_URL="postgresql://hyacine:change_this_password@localhost:5432/hyacine?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
PORT=3000
CORS_ORIGIN="http://localhost:8081,http://localhost:19006"

# JWT: use long, randomly generated values in real deployments.
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret-at-least-32-characters"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret-at-least-32-characters"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Optional NeteaseCloudMusicApi-compatible provider
NETEASE_API_BASE="http://localhost:3001"
