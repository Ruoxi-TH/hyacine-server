# Host port exposed by Docker Compose
API_PORT=3000

# Used by the PostgreSQL container and API connection string
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Browser origins only. Native mobile apps do not need a CORS origin.
CORS_ORIGIN=https://your-web-client.example

JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Required for Netease QR login, playlists, recommendations, and search.
# Deploy NeteaseCloudMusicApi separately, then use its reachable URL here.
NETEASE_API_BASE=http://your-netease-provider:3000